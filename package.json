{
  "name": "headless-paint",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @headless-paint/web dev",
    "build": "pnpm -r build && node ./scripts/verify-publish-artifacts.mjs",
    "publish:dry-run": "pnpm --filter @yuneco/headless-paint publish --access public --dry-run",
    "publish:packages": "pnpm --filter @yuneco/headless-paint publish --access public",
    "test": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
