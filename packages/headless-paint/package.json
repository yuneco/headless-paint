{
  "name": "@yuneco/headless-paint",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@headless-paint/core": "workspace:*",
    "@headless-paint/engine": "workspace:*",
    "@headless-paint/input": "workspace:*",
    "@headless-paint/react": "workspace:*",
    "@headless-paint/stroke": "workspace:*",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
